// ================================
// Activity Event Model
// ================================

model ActivityLogEvent {
    id         String     @id @default(auto()) @map("_id") @db.ObjectId
    tableName  String
    recordId   String
    action     actionType
    actionedBy String?    @db.ObjectId // user id who did the action
    ipAddress  String?
    userAgent  String?
    device     String?
    createdAt  DateTime   @default(now())
    eventType  eventType?

    // Relations
    details  ActivityLogEventDetail[]
    authUser authUser?                @relation(fields: [actionedBy], references: [id], onDelete: SetNull)

    @@index([tableName, recordId, createdAt]) // fetch history for a record
    @@index([actionedBy, createdAt]) // fetch actions by user
}

// ================================
// Activity Event Detail Model
// ================================

model ActivityLogEventDetail {
    id        String  @id @default(auto()) @map("_id") @db.ObjectId
    eventId   String  @db.ObjectId
    fieldName String
    oldValue  String?
    newValue  String?

    // Relations
    event ActivityLogEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([eventId])
}
